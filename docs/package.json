{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build && yarn prettier-api-reference && npm run postbuild",
    "docs:version": "./scripts/build-version-docs.sh",
    "postbuild": "node scripts/postbuild.mjs",
    "prettier-api-reference": "npx prettier --write 'docs/06-api-reference/**/*.{md,mdx}'",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docsearch/core": "^4.4.0",
    "@docsearch/css": "^4.6.0",
    "@docsearch/sidepanel": "^4.6.0",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/plugin-google-tag-manager": "^3.9.2",
    "@docusaurus/plugin-sitemap": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/react": "^3.0.0",
    "@mui/material": "^7.3.7",
    "@signalwire/docusaurus-plugin-llms-txt": "2.0.0-alpha.7",
    "@signalwire/docusaurus-theme-llms-txt": "1.0.0-alpha.9",
    "@swmansion/t-rex-ui": "^1.2.2",
    "clsx": "^2.1.0",
    "copy-text-to-clipboard": "^3.2.2",
    "prism-react-renderer": "^2.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "docusaurus-plugin-typedoc": "^1.4.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
