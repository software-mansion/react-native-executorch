{
  "name": "react-native-executorch",
  "version": "0.0.0",
  "description": "An easy way to run AI models in React Native with ExecuTorch",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "third-party",
    "*.podspec",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepack": "cp ../../README.md ./README.md",
    "postpack": "rm ./README.md"
  },
  "keywords": [
    "text-to-speech",
    "ocr",
    "computer-vision",
    "segmentation",
    "object-detection",
    "speech-to-text",
    "vlm",
    "image-embeddings",
    "on-device-ai",
    "text-embeddings",
    "llm",
    "ai",
    "react-native",
    "ios",
    "android",
    "executorch"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/software-mansion/react-native-executorch.git",
    "directory": "packages/react-native-executorch"
  },
  "author": "Software Mansion <hello@swmansion.com> (https://github.com/software-mansion)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/software-mansion/react-native-executorch/issues"
  },
  "homepage": "https://docs.swmansion.com/react-native-executorch",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-worklets": "*"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.6",
    "@types/react": "^19.1.12",
    "del-cli": "^6.0.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.40.18",
    "react-native-worklets": "0.9.1",
    "typescript": "~5.9.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RnExecutorchSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.swmansion.rnexecutorch"
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [],
    "version": "0.57.2"
  }
}
